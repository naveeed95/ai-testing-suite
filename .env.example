# ─────────────────────────────────────────────────────────────
# AI Testing Suite — Environment Variables
# ─────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it is already in .gitignore
# ─────────────────────────────────────────────────────────────

# Your Anthropic API key — get one at https://console.anthropic.com
# The app calls the Claude API directly from the browser.
# For production, proxy this through a backend to keep the key secret.
REACT_APP_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the default Claude model
REACT_APP_CLAUDE_MODEL=claude-sonnet-4-20250514
